<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartfactory.scada.plant.mapper.PlantMapper">
    <resultMap id="PlantResultMap" type="com.smartfactory.scada.plant.domain.Plant">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="companyType" column="company_type"/>
        <result property="address" column="address"/>
        <result property="latitude" column="latitude"/>
        <result property="longitude" column="longitude"/>
    </resultMap>

    <select id="findAll" resultMap="PlantResultMap">
        SELECT id, name, company_type, address, latitude, longitude
        FROM plants
        ORDER BY company_type, name
    </select>

    <select id="findById" resultMap="PlantResultMap">
        SELECT id, name, company_type, address, latitude, longitude
        FROM plants
        WHERE id = #{id}
    </select>
</mapper>
