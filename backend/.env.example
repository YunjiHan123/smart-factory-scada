# Copy this file to backend/.env and fill in the real values for your local machine.

# Server / Render
PORT=8080

# JWT
# Use a secret key with at least 32 bytes.
JWT_SECRET=replace-with-a-secret-key-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRATION_MS=300000
JWT_REFRESH_TOKEN_EXPIRATION_MS=3600000

# MySQL
DB_URL=jdbc:mysql://localhost:3306/scada
# Aiven example:
# DB_URL=jdbc:mysql://<aiven-mysql-host>:<port>/scada?sslMode=REQUIRED&serverTimezone=Asia/Seoul&characterEncoding=utf8
DB_USERNAME=replace-with-your-db-username
DB_PASSWORD=replace-with-your-db-password

# Server / CORS
PORT=8080
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://localhost:4173,https://your-vercel-app.vercel.app

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

# MQTT
MQTT_ENABLED=false
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=scada-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=scada/team5/plant/+/facility/+/energy

# OpenAI
# Leave OPENAI_API_KEY empty to use the local fallback chatbot answer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=10
OPENAI_MAX_OUTPUT_TOKENS=600
